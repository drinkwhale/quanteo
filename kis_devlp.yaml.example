# KIS Open Trading API 설정 예시 (open-trading-api 원본 포맷 기준)
# 실제 파일은 ~/KIS/config/kis_devlp.yaml 에 두세요 (저장소 밖, 커밋 금지).
# 경로 재지정: export QUANTEO_CONFIG_PATH=/원하는/경로/kis_devlp.yaml
#
# 앱키·시크릿 발급: https://apiportal.koreainvestment.com → 앱 등록
# ※ 실전투자·모의투자는 앱키가 별도로 발급됩니다. 두 환경 모두 등록하세요.

# ──────────────────────────────────────────────────────
# 앱키 / 시크릿
# ──────────────────────────────────────────────────────
my_app: "실전투자 앱키"
my_sec: "실전투자 앱키 시크릿"

paper_app: "모의투자 앱키"
paper_sec: "모의투자 앱키 시크릿"

# ──────────────────────────────────────────────────────
# HTS ID
# ──────────────────────────────────────────────────────
my_htsid: "사용자 HTS ID"

# ──────────────────────────────────────────────────────
# 계좌번호 앞 8자리
# ──────────────────────────────────────────────────────
my_acct_stock: "실전 증권계좌 8자리"
my_acct_future: "실전 선물옵션계좌 8자리"
my_paper_stock: "모의투자 증권계좌 8자리"
my_paper_future: "모의투자 선물옵션계좌 8자리"

# ──────────────────────────────────────────────────────
# 계좌번호 뒤 2자리 (상품코드)
# ──────────────────────────────────────────────────────
my_prod: "01"   # 종합계좌
# my_prod: "03" # 국내선물옵션계좌
# my_prod: "08" # 해외선물옵션계좌
# my_prod: "22" # 개인연금
# my_prod: "29" # 퇴직연금

# ──────────────────────────────────────────────────────
# 도메인 (KIS 공식 기본값 — 변경 불필요)
# ──────────────────────────────────────────────────────
prod: "https://openapi.koreainvestment.com:9443"
ops: "ws://ops.koreainvestment.com:21000"
vps: "https://openapivts.koreainvestment.com:29443"
vops: "ws://ops.koreainvestment.com:31000"

# ──────────────────────────────────────────────────────
# 공통
# ──────────────────────────────────────────────────────
my_token: ""
my_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36"

# ──────────────────────────────────────────────────────
# Telegram 알림 (선택 — quanteo 확장 필드)
# ──────────────────────────────────────────────────────
telegram:
  bot_token: "0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  chat_id: "-100123456789"          # 채널은 -100 접두사 필요
  level: "INFO"                     # INFO | WARN | ERROR
  enabled: false                    # true 로 바꾸면 실제 전송

# ──────────────────────────────────────────────────────
# Toss증권 Open API 자격증명 (broker: toss 사용 시)
# 발급: https://openapi.tossinvest.com → 앱 등록
# broker를 toss로 변경하면 KIS 섹션 대신 이 섹션을 사용한다.
# ──────────────────────────────────────────────────────
# toss:
#   client_id: "your-toss-client-id"
#   client_secret: "your-toss-client-secret"
