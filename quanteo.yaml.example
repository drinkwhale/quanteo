# quanteo 설정 예시
# 실제 파일은 ~/quanteo/config/quanteo.yaml 에 두세요 (저장소 밖, 커밋 금지).
# 경로 재지정: export QUANTEO_CONFIG_PATH=/원하는/경로/quanteo.yaml
#
# Toss증권 앱키 발급: https://openapi.tossinvest.com → 앱 등록

# ──────────────────────────────────────────────────────
# Toss증권 OAuth2 자격증명
# ──────────────────────────────────────────────────────
toss:
  client_id: "your-toss-client-id"
  client_secret: "your-toss-client-secret"

# ──────────────────────────────────────────────────────
# Telegram 알림 (선택)
# ──────────────────────────────────────────────────────
telegram:
  bot_token: "0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  chat_id: "-100123456789"   # 채널은 -100 접두사 필요, 개인은 숫자만
  level: "INFO"              # INFO | WARN | ERROR
  enabled: false             # true 로 바꾸면 실제 전송

# ──────────────────────────────────────────────────────
# Phase 10 — 정보 수집·알람 서브시스템 (선택)
# 실행 시 반드시 `--with-info` CLI 플래그도 함께 줘야 실제로 기동합니다.
# (enabled: true 만으로는 안 됩니다 — core/app.py의 with_info 인자와 AND 조건)
# ──────────────────────────────────────────────────────
info:
  enabled: false             # true 로 바꾸면 정보 수집 서브시스템 시작 (+ --with-info 필요)

  # DART 공시 수집
  # 1) https://opendart.fss.or.kr 가입 → 마이페이지 → "오픈API 이용신청"
  # 2) 발급된 인증키(40자리)를 아래에 붙여넣기. 승인은 즉시 처리됨.
  # 비워두면(빈 문자열) DART 수집기만 조용히 스킵되고 나머지는 정상 동작.
  dart:
    api_key: "your-dart-api-key"

  # Finnhub 해외 뉴스 (NVDA·MU·TSM·AMD·ASML 등)
  # 1) https://finnhub.io/register 가입 (무료 플랜으로 충분, 60 req/min 제한)
  # 2) 로그인 후 Dashboard 좌측 "API Key" 탭에서 키 복사
  # 비워두면 해외 뉴스 수집기만 스킵 (Yahoo RSS는 키 없이 계속 동작).
  finnhub:
    api_key: "your-finnhub-api-key"

  # Google Calendar OAuth2 — 최초 1회 브라우저 인증 필요
  # 절차 상세: docs/setup/GOOGLE_CALENDAR_SETUP.md 참고
  # 요약: GCP 콘솔에서 프로젝트 생성 → "Google Calendar API" 활성화
  #      → OAuth 클라이언트 ID(데스크톱 앱) 생성 → JSON 다운로드
  #      → 아래 경로에 저장 → 최초 실행 시 브라우저 동의 화면 뜨면 로그인
  #      → 이후 토큰은 자동 캐시·갱신됨 (재인증 불필요)
  google_calendar:
    credentials_path: "~/.quanteo/google/credentials.json"

  # Claude Haiku AI 중요도 필터 — 이 키만은 비워두지 말 것
  # (비어 있으면 키워드 매칭 폴백으로만 동작, 뉴스 분류 정확도 크게 하락)
  # 1) https://console.anthropic.com 가입/로그인
  # 2) Settings → API Keys → "Create Key"
  # 3) 발급된 sk-ant-... 키를 그대로 사용 (과금은 Haiku 기준 매우 저렴)
  anthropic:
    api_key: "your-anthropic-api-key"

  # 환율 급변 알람 임계값 (USD/KRW 기준 %)
  fx_alert_threshold: 1.0

  # info 전용 Telegram chat_id (비어 있으면 위 telegram.chat_id 사용)
  telegram:
    chat_id: ""

# ──────────────────────────────────────────────────────
# KIS(한국투자증권) Open Trading API — 자격증명 자리만 마련
# ⚠️ 아직 core/config/settings.py의 Settings 모델·어댑터에 연결되지 않음.
#    Phase 8-9에서 "KIS 완전 제거, Toss 단일 브로커" 결정을 내린 바 있어,
#    실제로 코드에서 쓰려면(시세 대조용이든 재통합이든) 먼저 별도 설계·승인이
#    필요하다. 지금은 값만 보관하는 자리.
# 발급: https://apiportal.koreainvestment.com → 개발자 등록 → 앱 발급
# (open-trading-api의 kis_devlp.yaml과 동일한 필드 구성)
# ──────────────────────────────────────────────────────
kis:
  app_key: "your-kis-app-key"
  app_secret: "your-kis-app-secret"
  paper_app_key: "your-kis-paper-app-key"
  paper_app_secret: "your-kis-paper-app-secret"
  hts_id: "your-hts-id"
  acct_stock: "00000000"        # 실전 증권계좌 (앞 8자리)
  acct_future: "00000000"       # 실전 선물옵션계좌 (앞 8자리)
  paper_acct_stock: "00000000"  # 모의투자 증권계좌 (앞 8자리)
  paper_acct_future: "00000000" # 모의투자 선물옵션계좌 (앞 8자리)
  acct_product_code: "01"       # 계좌번호 뒤 2자리(상품코드)
  prod_url: "https://openapi.koreainvestment.com:9443"
  vps_url: "https://openapivts.koreainvestment.com:29443"
  ops_ws_url: "ws://ops.koreainvestment.com:21000"
  vops_ws_url: "ws://ops.koreainvestment.com:31000"
